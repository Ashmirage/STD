*.axf
*.elf
*.hex
*.bin
*.map
*.lnp
*.dep
*.crf
*.d
*.o
*.iex
*.sct
*.bak
*.Bak

# Build logs / debug tool output
*.build_log.htm
JLinkLog.txt
JLinkSettings.ini

# Optional local output folder
/output/

# OS junk files
Thumbs.db
.DS_Store
